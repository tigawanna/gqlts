{
  "name": "integration-tests",
  "version": "3.4.0",
  "private": true,
  "homepage": "https://gqlts.vercel.app",
  "license": "MIT",
  "main": "index.js",
  "scripts": {
    "build": "echo 'no build needed'",
    "flame": "node --prof-process --preprocess -j isolate*.log | flamebearer && open flamegraph.html",
    "gen": "bun generate.ts && tsgo --noEmit",
    "genprof": "node --prof generate.ts",
    "test": "bun test --timeout 60000 ./tests/*.ts",
    "tsgo": "tsgo -p tsconfig.json --noEmit",
    "typecheck": "tsgo -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@apollo/server": "5.5.1",
    "@as-integrations/express5": "1.1.2",
    "@gqlts/cli": "workspace:*",
    "@gqlts/runtime": "workspace:*",
    "@graphql-tools/schema": "10.0.33",
    "await-sleep": "0.0.1",
    "axios": "1.16.1",
    "body-parser": "2.2.2",
    "deep-equal": "2.2.3",
    "express": "5.2.1",
    "graphql": "16.14.0",
    "graphql-easy-mocks": "1.1.1",
    "graphql-subscriptions": "3.0.0",
    "graphql-ws": "6.0.8",
    "tsd": "0.33.0",
    "tsdef": "0.0.14",
    "typescript": "6.0.3"
  },
  "devDependencies": {
    "@types/body-parser": "1.19.6",
    "@types/bun": "1.3.14",
    "@types/deep-equal": "1.0.4",
    "@types/node": "25.9.1",
    "@types/ws": "8.18.1"
  },
  "resolutions": {
    "graphql": "16.14.0",
    "ws": "8.21.0"
  }
}
