{
  "name": "demo-apps-try-clients",
  "version": "3.4.0",
  "private": true,
  "description": "",
  "keywords": [],
  "homepage": "https://gqlts.vercel.app",
  "license": "MIT",
  "main": "index.js",
  "scripts": {
    "build": "bun run gen && bun run github && bun run hasura && bun run simple",
    "gen": "bun run hasura && bun run github && bun run simple && tsgo --noEmit",
    "github": "bun run play --schema github.graphql -o github/generated -S HTML:string -S URI:string ",
    "hasura": "bun run play --schema hasura/generated/schema.graphql -o hasura/generated",
    "play": "bun ../../cli/src/cli.ts",
    "simple": "bun run play --esm-and-cjs --sort --schema simple.graphql -o simple/generated",
    "test": "bun test --timeout 60000 ./tests/*.ts",
    "tsgo": "tsgo -p tsconfig.json --noEmit",
    "typecheck": "tsgo -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@gqlts/cli": "workspace:*",
    "@gqlts/runtime": "workspace:*",
    "axios": "1.16.1",
    "compressed-json": "1.0.16",
    "dotenv": "17.4.2",
    "graphql": "16.14.0",
    "graphql-query-batcher": "1.0.1",
    "ibm-graphql-query-generator": "1.3.0",
    "isomorphic-unfetch": "4.0.2"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/node": "^25.6.0",
    "typescript": "6.0.3"
  }
}
