    "start": "next start",
    "subscription": "bun run play --esm -o subscription -e https://realtime-poll.hasura.app/v1/graphql",
    "test": "echo \"no test specified\"",
    "tsgo": "tsgo -p tsconfig.json --noEmit",
    "typecheck": "tsgo -p tsconfig.json --noEmit"
  },
