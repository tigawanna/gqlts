{
  "compilerOptions": {
    "incremental": true,
    "target": "ES2020",
    "ignoreDeprecations": "6.0",
    "types": ["bun", "node"],
    "module": "Node16",
    "lib": ["es5", "es6", "dom"],
    "moduleResolution": "node16",
    "resolveJsonModule": true,
    "allowJs": true,
    "checkJs": false,
    "sourceMap": false,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "skipDefaultLibCheck": true,
    "skipLibCheck": true,
    "declaration": true,
    "outDir": "./dist"
  },
  "include": ["*.ts"]
}
