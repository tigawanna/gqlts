{
  "name": "demo-apps-backend",
  "version": "3.4.0",
  "private": true,
  "homepage": "https://gqlts.vercel.app",
  "license": "MIT",
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "build-sdk": "bun run --cwd sdk build-sdk",
    "dev": "PORT=${PORT:-4000} bun --hot src/index.ts",
    "start": "PORT=${PORT:-4000} bun dist/index.js",
    "test": "NODE_ENV=test bun test --preload ./__tests__/setup.ts __tests__",
    "tsgo": "tsgo -p tsconfig.json --noEmit",
    "typecheck": "tsgo -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@envelop/parser-cache": "10.1.1",
    "@envelop/validation-cache": "10.1.1",
    "@graphql-tools/schema": "10.0.33",
    "graphql": "16.14.0",
    "graphql-scalars": "1.25.0",
    "graphql-upload-ts": "2.2.0",
    "graphql-yoga": "5.21.0",
    "nexus": "1.3.0",
    "supertest": "7.2.2",
    "typescript": "6.0.3"
  },
  "devDependencies": {
    "@gqlts/runtime": "workspace:*",
    "@types/bun": "1.3.14",
    "@types/node": "25.9.1",
    "@types/supertest": "7.2.0",
    "oxfmt": "0.52.0"
  }
}
